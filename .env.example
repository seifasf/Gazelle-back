NODE_ENV=production
# Render sets PORT automatically — do not hardcode in production.

# ── Required ──────────────────────────────────────────────────────────────
# MongoDB Atlas replica set (required for transactions)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/gazelle_oms?retryWrites=true&w=majority

# Min 16 characters — use Render "Generate" or: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Public URL of this API (no trailing slash). Used for Shopify + Bosta webhooks.
# Example: https://gazelle-api.onrender.com
APP_URL=https://your-api.onrender.com

# Frontend URL for CORS (comma-separated if multiple)
CORS_ORIGIN=https://gazelle-system.vercel.app

# ── Shopify (Admin API token — recommended) ──────────────────────────────
SHOPIFY_SHOP_DOMAIN=gazellefootwear.myshopify.com
SHOPIFY_API_VERSION=2025-01
SHOPIFY_ACCESS_TOKEN=shpat_xxx
SHOPIFY_WEBHOOK_SECRET=shpss_xxx
# Gazelle warehouse — Cairo (auto-detected on first connect if omitted)
SHOPIFY_LOCATION_ID=gid://shopify/Location/68179624162

# ── Bosta ────────────────────────────────────────────────────────────────
# Read/Write or Full Access key from Bosta dashboard (Authorization header, no Bearer prefix)
BOSTA_API_KEY=your-bosta-api-key
BOSTA_API_BASE_URL=https://app.bosta.co/api/v2

# ── Paymob ───────────────────────────────────────────────────────────────
# Webhook URL: {APP_URL}/webhooks/paymob  (Transaction processed callback)
# API key: pull successful transactions for the dashboard Paymob card
# HMAC: verify webhook authenticity (from Paymob Account Info)
# Public/Secret: Intention API / checkout (optional if payments stay on Shopify)
PAYMOB_API_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_SECRET_KEY=
PAYMOB_HMAC_SECRET=

# ── Brand expenses (USD lines like Website) ───────────────────────────────
USD_TO_EGP=50

# SEED_ADMIN_EMAIL=admin@gazellefootwear.com
# SEED_ADMIN_PASSWORD=your-secure-password
